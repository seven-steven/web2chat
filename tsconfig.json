{
  "extends": "./.wxt/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "paths": {
      "~/*": ["./*"],
      "@/*": ["./*"],
      "@/shared/*": ["./shared/*"],
      "#i18n": ["./.wxt/i18n/index.ts"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "wxt.config.ts", "scripts/**/*.ts", ".wxt/wxt.d.ts"]
}
